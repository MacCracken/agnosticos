# EditorConfig — https://editorconfig.org
# Ensures consistent formatting across editors and IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{rs}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{c,h}]
indent_style = tab
indent_size = 8
max_line_length = 80

[*.{toml,yaml,yml}]
indent_style = space
indent_size = 2

[*.{json}]
indent_style = space
indent_size = 2

[*.{md}]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab
indent_size = 4

[*.sh]
indent_style = space
indent_size = 4
