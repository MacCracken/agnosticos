# AGNOS Python 3.14 Base Image
#
# Layers Python 3.14 + common ML/QA system libraries on top of the AGNOS
# runtime image. Experimental — Python 3.14 is in release candidate.
#
# Published as: ghcr.io/maccracken/agnosticos:python3.14

FROM ghcr.io/maccracken/agnosticos:latest

USER root

# ── Python 3.14 (from Debian testing/experimental) ────────────────────────
# Debian trixie ships 3.13 by default; install 3.14 from source or
# deadsnakes-style PPA when available. For now, use system python3 (3.13)
# and this image serves as the forward-compat target.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    gcc \
    g++ \
    make \
    pkg-config \
    # OpenCV / computer vision
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    libgthread-2.0-0 \
    # Crypto / SSL
    libssl-dev \
    libffi-dev \
    # Playwright browser automation
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    git \
    && rm -rf /var/lib/apt/lists/*

# ── Base Python packages ──────────────────────────────────────────────────
COPY docker/requirements-base.txt /tmp/requirements-base.txt
RUN pip install --no-cache-dir --break-system-packages \
    -r /tmp/requirements-base.txt \
    && rm /tmp/requirements-base.txt

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

LABEL org.opencontainers.image.title="AGNOS Python 3.14"
LABEL org.opencontainers.image.description="Python 3.14 with ML/QA system libraries on AGNOS"
LABEL org.opencontainers.image.vendor="AGNOS"
LABEL org.opencontainers.image.base.name="ghcr.io/maccracken/agnosticos:latest"

USER agnos
WORKDIR /home/agnos

ENTRYPOINT ["python3"]
