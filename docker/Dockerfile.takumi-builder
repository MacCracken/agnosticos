# AGNOS Takumi Builder — Container for building .ark packages from source
# This provides a reproducible build environment matching the AGNOS target system.
#
# Usage:
#   docker build -f docker/Dockerfile.takumi-builder -t agnos:takumi-builder .
#
# Build a single package:
#   docker run --rm -v ./recipes:/recipes:ro -v ./dist/ark:/output \
#       agnos:takumi-builder /recipes/python/cpython-3.12.toml
#
# Build all packages:
#   docker run --rm -v ./recipes:/recipes:ro -v ./dist/ark:/output \
#       --entrypoint /usr/local/bin/ark-build-all \
#       agnos:takumi-builder /recipes/
#
# With source cache (persistent across builds):
#   docker run --rm \
#       -v ./recipes:/recipes:ro \
#       -v ./dist/ark:/output \
#       -v takumi-cache:/cache \
#       agnos:takumi-builder /recipes/database/postgresql-17.toml

FROM debian:bookworm AS builder

LABEL org.opencontainers.image.title="AGNOS Takumi Builder"
LABEL org.opencontainers.image.description="Reproducible build environment for .ark packages"

# ---------------------------------------------------------------------------
# Core build essentials
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    pkg-config \
    autoconf \
    automake \
    libtool \
    cmake \
    ninja-build \
    curl \
    wget \
    ca-certificates \
    xz-utils \
    file \
    patch \
    git \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Python build dependencies
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    zlib1g-dev \
    libffi-dev \
    libssl-dev \
    libbz2-dev \
    liblzma-dev \
    libreadline-dev \
    libncurses5-dev \
    libsqlite3-dev \
    libgdbm-dev \
    libexpat1-dev \
    libmpdec-dev \
    uuid-dev \
    # PGO/LTO builds
    llvm \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# PostgreSQL build dependencies
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    bison \
    flex \
    perl \
    python3 \
    libxml2-dev \
    libxslt1-dev \
    libicu-dev \
    liblz4-dev \
    libzstd-dev \
    libpam0g-dev \
    libsystemd-dev \
    libuuid1 \
    llvm-dev \
    clang \
    docbook-xsl \
    libkrb5-dev \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Redis build dependencies (minimal — uses bundled deps)
# ---------------------------------------------------------------------------
# openssl-dev already installed above; Redis only needs basic build tools
# plus systemd for notify support
RUN apt-get update && apt-get install -y --no-install-recommends \
    tcl \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Browser build dependencies (Firefox, Chromium)
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Rust toolchain (for Firefox/Servo)
    rustc \
    cargo \
    # Firefox build deps
    nasm \
    yasm \
    nodejs \
    npm \
    zip \
    unzip \
    m4 \
    # GTK/Wayland deps
    libgtk-3-dev \
    libx11-dev \
    libxcomposite-dev \
    libxdamage-dev \
    libxext-dev \
    libxfixes-dev \
    libxrandr-dev \
    libxrender-dev \
    libdbus-1-dev \
    libdbus-glib-1-dev \
    libasound2-dev \
    libpulse-dev \
    libnss3-dev \
    libnspr4-dev \
    libfontconfig1-dev \
    libfreetype-dev \
    libharfbuzz-dev \
    libpixman-1-dev \
    libcairo2-dev \
    libpango1.0-dev \
    libgdk-pixbuf-2.0-dev \
    libdrm-dev \
    libwayland-dev \
    wayland-protocols \
    libpipewire-0.3-dev \
    # Chromium deps
    gperf \
    libcups2-dev \
    libkrb5-dev \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Cross-compilation toolchains (arm64, armhf, riscv64)
# ---------------------------------------------------------------------------
RUN dpkg --add-architecture arm64 && \
    dpkg --add-architecture armhf && \
    apt-get update && apt-get install -y --no-install-recommends \
    # ARM64 (aarch64) cross toolchain
    gcc-aarch64-linux-gnu \
    g++-aarch64-linux-gnu \
    binutils-aarch64-linux-gnu \
    # ARMv7 (armhf) cross toolchain
    gcc-arm-linux-gnueabihf \
    g++-arm-linux-gnueabihf \
    binutils-arm-linux-gnueabihf \
    # RISC-V 64 cross toolchain (if available)
    gcc-riscv64-linux-gnu \
    g++-riscv64-linux-gnu \
    binutils-riscv64-linux-gnu \
    # QEMU user-mode emulation (for running cross-built test binaries)
    qemu-user-static \
    binfmt-support \
    # Cross-arch pkg-config support
    crossbuild-essential-arm64 \
    crossbuild-essential-armhf \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Rust cross-compilation targets
# ---------------------------------------------------------------------------
RUN rustup target add aarch64-unknown-linux-gnu \
                      armv7-unknown-linux-gnueabihf \
                      riscv64gc-unknown-linux-gnu \
    2>/dev/null || true

# ---------------------------------------------------------------------------
# Ed25519 signing support (for ark-sign.sh)
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    xxd \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Create build user (non-root builds)
# ---------------------------------------------------------------------------
RUN useradd --system --create-home --shell /bin/bash takumi \
    && mkdir -p /build /output /cache \
    && chown -R takumi:takumi /build /output /cache

# Copy the build scripts
COPY scripts/ark-build.sh /usr/local/bin/ark-build
COPY scripts/ark-build-all.sh /usr/local/bin/ark-build-all
COPY scripts/ark-sign.sh /usr/local/bin/ark-sign
RUN chmod +x /usr/local/bin/ark-build /usr/local/bin/ark-build-all /usr/local/bin/ark-sign

WORKDIR /build
USER takumi

ENTRYPOINT ["/usr/local/bin/ark-build"]
