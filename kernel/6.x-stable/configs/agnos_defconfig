# AGNOS Kernel Configuration
# Linux 6.6 LTS Hardened Configuration
# Based on x86_64 architecture

# Base kernel settings
CONFIG_LOCALVERSION="-agnos"
CONFIG_LOCALVERSION_AUTO=y

# Processor type and features
CONFIG_SMP=y
CONFIG_X86_64=y
CONFIG_X86_INTEL_LPSS=y
CONFIG_X86_AMD_PLATFORM_DEVICE=y
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_XEN=y
CONFIG_KVM_GUEST=y

# Security features
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_LANDLOCK=y
CONFIG_SECURITY_SECCOMP=y
CONFIG_SECURITY_SECCOMP_FILTER=y
CONFIG_SECURITY_YAMA=y
CONFIG_SECURITY_SAFESETID=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_INTEGRITY=y
CONFIG_IMA=y
CONFIG_EVM=y
CONFIG_DEFAULT_SECURITY_SELINUX=y

# Memory protection
CONFIG_PAGE_TABLE_ISOLATION=y
CONFIG_RETPOLINE=y

# Namespaces
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_TIME_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_USER_NS_UNPRIVILEGED=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_CGROUP_NS=y

# cgroups
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_RDMA=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_MISC=y

# BPF
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_LSM=y

# Seccomp
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Kernel module settings
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_SHA256=y

# AGNOS-specific kernel modules
CONFIG_AGNOS_SECURITY=m
CONFIG_AGNOS_AGENT_SUBSYSTEM=m
CONFIG_AGNOS_LLM=m
CONFIG_AGNOS_AUDIT=m

# File systems
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_BTRFS_FS=y
CONFIG_XFS_FS=y
CONFIG_FANOTIFY=y
CONFIG_OVERLAY_FS=y

# Networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NF_TABLES=y

# CIS 1.1.5 - Disable automounting
CONFIG_AUTOMOUNT=n

# CIS 1.1.6 - Disable USB storage (attack vector reduction)
CONFIG_USB_STORAGE=n

# CIS 1.1.7 - Disable FireWire (DMA attack prevention)
CONFIG_FIREWIRE=n
CONFIG_FIREWIRE_OHCI=n

# CIS 1.1.8 - Disable Thunderbolt (DMA attack prevention)
CONFIG_THUNDERBOLT=n

# Disable uncommon network protocols (CIS 3.4.x)
CONFIG_SCTP=n
CONFIG_RDS=n
CONFIG_TIPC=n
CONFIG_DCCP=n

# Disable unused filesystems
CONFIG_NFSD=n
CONFIG_CRAMFS=n
CONFIG_FREEVXFS_FS=n
CONFIG_JFFS2_FS=n
CONFIG_HFS_FS=n
CONFIG_HFSPLUS_FS=n
CONFIG_UDF_FS=n

# Device drivers
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_SATA_AHCI=y
CONFIG_NVME_CORE=y

# Graphics
CONFIG_DRM=y
CONFIG_DRM_I915=y
CONFIG_DRM_AMDGPU=y

# Virtualization
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y

# Power management
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# Crypto
CONFIG_CRYPTO=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_GCM=y

# AppArmor support
CONFIG_SECURITY_APPARMOR=y

# Boot options
CONFIG_CMDLINE="quiet loglevel=3 agnos.security.enforce=1 agnos.audit.enabled=1 audit=1 audit_backlog_limit=8192"
