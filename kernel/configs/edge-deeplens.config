# AGNOS Edge — AWS DeepLens kernel config fragment
# x86_64 target (Intel Atom x5-Z8350, Cherry Trail)
# Apply on top of the base edge_x86_64_defconfig
#
# DeepLens-specific: Intel Atom CPU, HD 400 GPU (i915),
# Intel 8265 WiFi, USB camera (UVC), 8 GB RAM

# --- Architecture ---
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4
CONFIG_ACPI=y
CONFIG_EFI=y

# --- CPU (Atom / Cherry Trail) ---
CONFIG_MATOM=y
CONFIG_INTEL_IDLE=y
CONFIG_CPU_FREQ=y
CONFIG_X86_INTEL_PSTATE=y
CONFIG_X86_ACPI_CPUFREQ=y
CONFIG_INTEL_RAPL=m

# --- Graphics (Intel HD 400 / Cherry Trail) ---
CONFIG_DRM=y
CONFIG_DRM_I915=m

# --- WiFi (Intel 8265) ---
CONFIG_IWLWIFI=m
CONFIG_IWLMVM=m

# --- USB (camera, peripherals) ---
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y

# --- Camera (UVC for DeepLens built-in camera) ---
CONFIG_MEDIA_SUPPORT=m
CONFIG_MEDIA_USB_SUPPORT=y
CONFIG_USB_VIDEO_CLASS=m
CONFIG_VIDEO_DEV=m
CONFIG_VIDEO_V4L2=m

# --- Audio (Intel Atom) ---
CONFIG_SND=m
CONFIG_SND_HDA_INTEL=m
CONFIG_SND_SOC_INTEL_ATOM=m
CONFIG_SND_SOC_INTEL_CHT_BSW_MAX98090=m

# --- Storage (eMMC) ---
CONFIG_MMC=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_ACPI=y

# --- Networking (Ethernet) ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_R8169=m

# --- Thermal / power (critical for fanless Atom) ---
CONFIG_THERMAL=y
CONFIG_INT340X_THERMAL=m
CONFIG_INTEL_SOC_DTS_THERMAL=m
CONFIG_CPU_THERMAL=y

# --- Watchdog ---
CONFIG_WATCHDOG=y
CONFIG_ITCO_WDT=m

# --- Filesystem (read-only rootfs) ---
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_OVERLAY_FS=y
CONFIG_DM_VERITY=y
