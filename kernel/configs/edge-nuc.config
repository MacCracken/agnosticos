# AGNOS Edge — Intel NUC kernel config fragment
# x86_64 target
# Apply on top of the base edge_x86_64_defconfig

# --- Architecture ---
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_ACPI=y
CONFIG_EFI=y

# --- CPU power management ---
CONFIG_INTEL_IDLE=y
CONFIG_CPU_FREQ=y
CONFIG_X86_INTEL_PSTATE=y
CONFIG_INTEL_RAPL=m

# --- Graphics (Intel UHD / Iris) ---
CONFIG_DRM=y
CONFIG_DRM_I915=m

# --- WiFi (Intel AX series) ---
CONFIG_IWLWIFI=m
CONFIG_IWLMVM=m
CONFIG_IWLDVM=m

# --- Audio (Intel HDA) ---
CONFIG_SND=m
CONFIG_SND_HDA_INTEL=m
CONFIG_SND_HDA_CODEC_REALTEK=m

# --- NVMe / SATA ---
CONFIG_BLK_DEV_NVME=y
CONFIG_ATA=y
CONFIG_SATA_AHCI=y

# --- USB ---
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y

# --- Thunderbolt ---
CONFIG_THUNDERBOLT=m
CONFIG_USB4=m

# --- Networking ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_E1000E=m
CONFIG_IGB=m

# --- Thermal / power ---
CONFIG_THERMAL=y
CONFIG_INT340X_THERMAL=m
CONFIG_INTEL_PCH_THERMAL=m

# --- Watchdog ---
CONFIG_WATCHDOG=y
CONFIG_ITCO_WDT=m

# --- Filesystem (read-only rootfs) ---
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_OVERLAY_FS=y
CONFIG_DM_VERITY=y
