# AGNOS Edge — Raspberry Pi 5 (BCM2712) kernel config fragment
# ARM64 / AArch64 target
# Apply on top of the base edge_aarch64_defconfig

# --- Architecture ---
CONFIG_ARM64=y
CONFIG_ARCH_BCM2835=y

# --- SoC / platform ---
CONFIG_BCM2835_MBOX=y
CONFIG_BCM2835_POWER=y
CONFIG_BCM2835_WDT=y
CONFIG_BCM2835_THERMAL=y

# --- RPi 5 specific: RP1 south bridge + PCIe ---
CONFIG_PCIE_BRCMSTB=y
CONFIG_MFD_RP1=y
CONFIG_PINCTRL_RP1=y

# --- SPI ---
CONFIG_SPI=y
CONFIG_SPI_BCM2835=m
CONFIG_SPI_BCM2835AUX=m

# --- I2C ---
CONFIG_I2C=y
CONFIG_I2C_BCM2835=m
CONFIG_I2C_DESIGNWARE_PLATFORM=m

# --- GPIO ---
CONFIG_GPIO_BCM_VIRT=y
CONFIG_PINCTRL_BCM2835=y

# --- Graphics (VideoCore) ---
CONFIG_DRM=y
CONFIG_DRM_VC4=m
CONFIG_DRM_V3D=m

# --- MMC / SD card ---
CONFIG_MMC=y
CONFIG_MMC_BCM2835=y
CONFIG_MMC_SDHCI_IPROC=y

# --- USB ---
CONFIG_USB=y
CONFIG_USB_DWC2=m
CONFIG_USB_XHCI_HCD=y

# --- NVMe (via PCIe on RPi 5) ---
CONFIG_BLK_DEV_NVME=y

# --- Networking (minimal) ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_GENET=y
CONFIG_BRCMFMAC=m

# --- Thermal / power ---
CONFIG_THERMAL=y
CONFIG_CPU_FREQ=y
CONFIG_CPUFREQ_DT=y

# --- Watchdog ---
CONFIG_WATCHDOG=y

# --- Filesystem (read-only rootfs) ---
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_OVERLAY_FS=y
CONFIG_DM_VERITY=y
